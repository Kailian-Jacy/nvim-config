{
  "HTTP GET Request": {
    "prefix": "httpget",
    "body": [
      "# @name ${1:request-name}",
      "# # @proxy http://127.0.0.1:7891",
      "# # @timeout 10",
      "# # @debug",
      "",
      "GET ${2:https://example.com/api/endpoint} HTTP/1.1",
      "# Accept: application/json",
      "# Authorization: Bearer ${3:token}",
      "# Cookie: ${4:session=abc123}",
      "# Cache-Control: no-cache",
      "",
      "$0"
    ],
    "description": "HTTP GET request with common headers as comments"
  },
  "HTTP POST Request": {
    "prefix": "httppost",
