      "# Authorization: Bearer ${4:token}",
      "# Cookie: ${5:session=abc123}",
      "# Accept: application/json",
      "",
      "{",
      "  \"${6:key}\": \"${7:value}\"",
      "}",
      "",
      "$0"
    ],
    "description": "HTTP POST request with JSON body and common headers"
  },
